# =========================
# KIE Agent deployment env
# Copy this file to .env before running docker compose.
# =========================

# Public access ports on the server
BACKEND_PORT=8001
FRONTEND_PORT=5173

# Backend -> LLM service
# Must be reachable from inside Docker containers.
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=Qwen3.5-35B-A3B-GPTQ-Int4
LLM_API_KEY=EMPTY

# Frontend build-time API base URL
# Direct exposure example:
#   http://SERVER_IP:8001
# Reverse proxy example:
#   https://your-domain.com
VITE_API_BASE_URL=http://SERVER_IP:8001

# Backend runtime options
LLM_MAX_RETRIES=2
LLM_RESPONSE_EXCERPT_LIMIT=500
LOG_LEVEL=INFO

# JSON array string for FastAPI CORS
# Example:
# CORS_ORIGINS=["https://your-domain.com"]
CORS_ORIGINS=["*"]
